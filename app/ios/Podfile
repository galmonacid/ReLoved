platform :ios, '13.0'
require 'fileutils'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcconfig = File.expand_path('Flutter/Generated.xcconfig', __dir__)
  unless File.exist?(generated_xcconfig)
    raise "Generated.xcconfig not found at #{generated_xcconfig}. Run flutter pub get first."
  end

  File.foreach(generated_xcconfig) do |line|
    match = line.match(/FLUTTER_ROOT=(.*)/)
    return match[1].strip if match
  end

  raise "FLUTTER_ROOT not found in #{generated_xcconfig}."
end

require File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper')

flutter_ios_podfile_setup

target 'Runner' do
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['CLANG_WARN_NON_MODULAR_INCLUDE_IN_FRAMEWORK_MODULE'] = 'NO'
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'

      %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS OTHER_LDFLAGS].each do |key|
        value = config.build_settings[key]
        if value.is_a?(Array)
          cleaned = value.reject do |flag|
            flag_s = flag.to_s
            flag_s.start_with?('-G') ||
              flag_s.include?('GCC_WARN_INHIBIT_ALL_WARNINGS') ||
              flag_s == '-Werror=non-modular-include-in-framework-module'
          end
          if %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS].include?(key)
            cleaned << '-Wno-error=non-modular-include-in-framework-module'
            cleaned << '-Wno-non-modular-include-in-framework-module'
          end
          config.build_settings[key] = cleaned.uniq
        elsif value.is_a?(String)
          cleaned = value.split(' ').reject do |flag|
            flag_s = flag.to_s
            flag_s.start_with?('-G') ||
              flag_s.include?('GCC_WARN_INHIBIT_ALL_WARNINGS') ||
              flag_s == '-Werror=non-modular-include-in-framework-module'
          end
          if %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS].include?(key)
            cleaned << '-Wno-error=non-modular-include-in-framework-module'
            cleaned << '-Wno-non-modular-include-in-framework-module'
          end
          config.build_settings[key] = cleaned.uniq.join(' ')
        end
      end
    end

    next unless target.name == 'BoringSSL-GRPC'

    # Xcode 16 may choke on this malformed flag emitted by older BoringSSL-GRPC specs.
    target.source_build_phase.files.each do |file|
      next unless file.settings&.key?('COMPILER_FLAGS')

      flags = file.settings['COMPILER_FLAGS'].to_s.split(' ')
      flags = flags.reject { |flag| flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS' || flag.start_with?('-G') }
      file.settings['COMPILER_FLAGS'] = flags.join(' ')
    end
  end

  # Xcode 16 + some gRPC-Core versions fail to parse this line:
  # `Traits::template CallSeqFactory(...)`.
  %w[gRPC-Core gRPC-C++].each do |grpc_target|
    grpc_basic_seq = File.join(
      installer.sandbox.root.to_s,
      grpc_target,
      'src',
      'core',
      'lib',
      'promise',
      'detail',
      'basic_seq.h'
    )
    next unless File.exist?(grpc_basic_seq)

    content = File.read(grpc_basic_seq)
    patched = content.gsub('Traits::template CallSeqFactory', 'Traits::CallSeqFactory')
    File.write(grpc_basic_seq, patched) if patched != content
  end

  # When using modular headers without `use_frameworks!`, gRPC-C++ can look for
  # this modulemap in Headers/Private/grpc and fail if missing.
  grpc_modulemap_candidates = Dir.glob(
    File.join(installer.sandbox.root.to_s, '**', 'gRPC-Core.modulemap')
  )
  grpc_modulemap_src = grpc_modulemap_candidates.find { |path| path.include?('Target Support Files') } ||
                       grpc_modulemap_candidates.first
  grpc_modulemap_dst_dir = File.join(
    installer.sandbox.root.to_s,
    'Headers',
    'Private',
    'grpc'
  )
  grpc_modulemap_dst = File.join(grpc_modulemap_dst_dir, 'gRPC-Core.modulemap')
  if File.exist?(grpc_modulemap_src)
    FileUtils.mkdir_p(grpc_modulemap_dst_dir)
    src_realpath = File.realpath(grpc_modulemap_src) rescue grpc_modulemap_src
    dst_realpath = File.exist?(grpc_modulemap_dst) ? (File.realpath(grpc_modulemap_dst) rescue grpc_modulemap_dst) : nil
    if dst_realpath != src_realpath
      # Write avoids FileUtils.cp "same file" failures when symlinks collapse to the same inode.
      File.write(grpc_modulemap_dst, File.read(grpc_modulemap_src))
    end
  end
end
