{
  "name": "reloved-functions",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test:functions": "node --test tests/send_contact_email.test.cjs",
    "test:chat": "node --test tests/chat_functions.test.cjs",
    "test:rules": "node --test --test-concurrency=1 tests/rules.test.cjs",
    "test:integration": "node --test --test-concurrency=1 tests/integration_flows.test.cjs tests/chat_functions.test.cjs"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.1"
  },
  "overrides": {
    "axios": "^1.13.6",
    "fast-xml-parser": "^5.5.1",
    "minimatch": "^9.0.7",
    "qs": "^6.15.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.1",
    "typescript": "^5.5.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "firebase-functions-test": "^3.4.0"
  }
}
